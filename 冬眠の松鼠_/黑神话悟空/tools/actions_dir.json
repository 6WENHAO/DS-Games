[
  { "type": "eval", "expr": "JSON.stringify({camYaw:Math.round(window.__game.tpCamera.yaw*100)/100,playerYaw:Math.round(window.__game.player.yaw*100)/100,pos:window.__game.player.position.toArray().map(v=>Math.round(v*10)/10)})" },
  { "type": "eval", "expr": "window.__game.input.keys.add('KeyW')" },
  { "type": "wait", "ms": 6000 },
  { "type": "eval", "expr": "window.__game.input.keys.delete('KeyW')" },
  { "type": "eval", "expr": "JSON.stringify({posAfterW:window.__game.player.position.toArray().map(v=>Math.round(v*10)/10),playerYaw:Math.round(window.__game.player.yaw*100)/100})" },
  { "type": "eval", "expr": "window.__game.input.keys.add('KeyD')" },
  { "type": "wait", "ms": 3000 },
  { "type": "eval", "expr": "window.__game.input.keys.delete('KeyD')" },
  { "type": "eval", "expr": "JSON.stringify({posAfterD:window.__game.player.position.toArray().map(v=>Math.round(v*10)/10),playerYaw:Math.round(window.__game.player.yaw*100)/100})" },
  { "type": "shot", "out": "downloads/dir_check.png" }
]

[
  { "type": "eval", "expr": "(()=>{const g=window.__game;g.player.group.position.set(0,g.world.getHeight(0,-60),-60);return 'teleported'})()" },
  { "type": "wait", "ms": 1200 },
  { "type": "eval", "expr": "JSON.stringify({bossState:window.__game.boss.state,bossActive:window.__game.combat.bossActive})" },
  { "type": "wait", "ms": 4000 },
  { "type": "shot", "out": "downloads/boss1.png" },
  { "type": "eval", "expr": "JSON.stringify({bossState:window.__game.boss.state,bossHp:window.__game.boss.hp})" },
  { "type": "eval", "expr": "(()=>{const g=window.__game;g.boss.takeDamage(500,g.player.position,{heavy:true});return JSON.stringify({hp:g.boss.hp,phase:g.boss.phase})})()" },
  { "type": "wait", "ms": 2500 },
  { "type": "shot", "out": "downloads/boss2.png" },
  { "type": "eval", "expr": "JSON.stringify({state:window.__game.boss.state,phase:window.__game.boss.phase,projectiles:window.__game.combat.projectiles.length,playerHp:window.__game.player.hp})" },
  { "type": "eval", "expr": "(()=>{const g=window.__game;g.boss.takeDamage(600,g.player.position,{heavy:true});return 'kill'})()" },
  { "type": "wait", "ms": 4000 },
  { "type": "shot", "out": "downloads/boss3.png" },
  { "type": "eval", "expr": "JSON.stringify({state:window.__game.boss.state,gameState:window.__game.state,victoryShown:!document.getElementById('overlay-victory').classList.contains('hidden')})" }
]

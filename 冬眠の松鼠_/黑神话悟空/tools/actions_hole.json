[
  { "type": "eval", "expr": "(()=>{const g=window.__game;const e=g.combat.enemies;for(let i=0;i<5;i++){const en=e[i];en.group.position.set(g.player.position.x+2+i*1.8,0,g.player.position.z-7);en.state='idle';en.snapToGround();}g.player.castHole();return 'hole cast cd='+g.player.holeCd})()" },
  { "type": "wait", "ms": 1200 },
  { "type": "eval", "expr": "(()=>{const bh=window.__game.combat.blackHole;for(let i=0;i<4;i++)bh.update(0.3);return JSON.stringify({active:bh.active,victims:bh.victims.length,t:Math.round(bh.time*10)/10})})()" },
  { "type": "shot", "out": "downloads/hole_pull.png" },
  { "type": "eval", "expr": "(()=>{const bh=window.__game.combat.blackHole;for(let i=0;i<8;i++)bh.update(0.3);return JSON.stringify({t:Math.round(bh.time*10)/10,swallowed:bh.victims.filter(v=>v.swallowed).length,done:bh.victims.filter(v=>v.done).length,alive:window.__game.combat.enemies.filter(e=>e.alive).length})})()" },
  { "type": "eval", "expr": "(()=>{const bh=window.__game.combat.blackHole;for(let i=0;i<8;i++)bh.update(0.3);const g=window.__game;return JSON.stringify({active:bh.active,alive:g.combat.enemies.filter(e=>e.alive).length,anyLifted:g.combat.enemies.some(e=>e.lifted),souls:g.player.souls})})()" },
  { "type": "eval", "expr": "(()=>{const g=window.__game;g.player.holeCd=0;g.player.group.position.set(0,g.world.getHeight(0,-62),-62);g.player.snapToGround();return 'tp arena'})()" },
  { "type": "wait", "ms": 2500 },
  { "type": "eval", "expr": "(()=>{const g=window.__game;g.boss.setState('idle');g.player.castHole();return 'hole on boss'})()" },
  { "type": "wait", "ms": 1000 },
  { "type": "eval", "expr": "(()=>{const bh=window.__game.combat.blackHole;for(let i=0;i<20;i++)bh.update(0.3);const g=window.__game;return JSON.stringify({active:bh.active,bossState:g.boss.state,bossHp:g.boss.hp,bossVisible:g.boss.group.visible,errs:window.__errors})})()" }
]

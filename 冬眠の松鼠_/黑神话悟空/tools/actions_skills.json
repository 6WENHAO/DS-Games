[
  { "type": "eval", "expr": "(()=>{const g=window.__game;g.player.castClone();return 'castClone cd='+g.player.cloneCd})()" },
  { "type": "wait", "ms": 2500 },
  { "type": "eval", "expr": "JSON.stringify({clones:window.__game.combat.clones.length,alive:window.__game.combat.clones.filter(c=>c.alive).length,states:window.__game.combat.clones.map(c=>c.state)})" },
  { "type": "eval", "expr": "(()=>{const g=window.__game;const e=g.combat.enemies.find(x=>x.alive);e.state='idle';const c=g.combat.clones[0];if(c){c.group.position.set(e.position.x+1.5,0,e.position.z);}return 'clone moved near '+e.type})()" },
  { "type": "wait", "ms": 4000 },
  { "type": "eval", "expr": "JSON.stringify({enemyHp:window.__game.combat.enemies[0].hp,enemyMax:window.__game.combat.enemies[0].maxHp,cloneState:window.__game.combat.clones[0]?window.__game.combat.clones[0].state:'gone'})" },
  { "type": "shot", "out": "downloads/skill_clone.png" },
  { "type": "eval", "expr": "(()=>{const g=window.__game;const e=g.combat.enemies[0];return JSON.stringify({enemyTarget:g.combat.pickTargetFor(e)===g.player?'player':'clone'})})()" },
  { "type": "eval", "expr": "(()=>{const g=window.__game;g.player.castGuard();return JSON.stringify({guardTime:Math.round(g.player.guardTime*10)/10,guardCd:g.player.guardCd})})()" },
  { "type": "wait", "ms": 500 },
  { "type": "eval", "expr": "(()=>{const g=window.__game;const hp0=g.player.hp;g.player.iframes=0;g.player.takeDamage(40,null);return JSON.stringify({hp0,hp1:g.player.hp,expected:'40->~10 dmg',state:g.player.state})})()" },
  { "type": "wait", "ms": 800 },
  { "type": "eval", "expr": "(()=>{const g=window.__game;g.player.guardTime=0;g.player.iframes=0;const hp0=g.player.hp;g.player.takeDamage(20,null);return JSON.stringify({noGuardHp0:hp0,noGuardHp1:g.player.hp,state:g.player.state})})()" }
]

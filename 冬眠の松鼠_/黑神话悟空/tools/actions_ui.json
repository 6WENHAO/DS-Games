[
  { "type": "shot", "out": "downloads/ui_title.png" },
  { "type": "eval", "expr": "(()=>{document.getElementById('btn-start').click();return window.__game.state})()" },
  { "type": "wait", "ms": 1500 },
  { "type": "shot", "out": "downloads/ui_hud.png" },
  { "type": "eval", "expr": "JSON.stringify({state:window.__game.state,hudHidden:document.getElementById('hud').classList.contains('hidden')})" },
  { "type": "eval", "expr": "(()=>{window.__game.player.takeDamage(9999,null);return 'killed'})()" },
  { "type": "wait", "ms": 2500 },
  { "type": "shot", "out": "downloads/ui_death.png" },
  { "type": "eval", "expr": "JSON.stringify({state:window.__game.state,deathShown:!document.getElementById('overlay-death').classList.contains('hidden')})" },
  { "type": "eval", "expr": "(()=>{document.getElementById('btn-respawn').click();return 'respawn'})()" },
  { "type": "wait", "ms": 800 },
  { "type": "eval", "expr": "JSON.stringify({state:window.__game.state,hp:window.__game.player.hp,pos:window.__game.player.position.toArray().map(v=>Math.round(v))})" },
  { "type": "eval", "expr": "(()=>{window.__game.combat.onBossDefeated(window.__game.boss);return 'winTrigger'})()" },
  { "type": "wait", "ms": 3000 },
  { "type": "shot", "out": "downloads/ui_victory.png" },
  { "type": "eval", "expr": "JSON.stringify({state:window.__game.state,victoryShown:!document.getElementById('overlay-victory').classList.contains('hidden')})" }
]

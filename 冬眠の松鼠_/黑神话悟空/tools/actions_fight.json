[
  { "type": "eval", "expr": "(()=>{const g=window.__game;const e=g.combat.enemies.find(x=>x.alive);g.player.group.position.set(e.position.x+1.5,0,e.position.z);g.player.snapToGround();const d=e.position.clone().sub(g.player.position);g.player.yaw=Math.atan2(d.x,d.z);return 'near '+e.type})()" },
  { "type": "wait", "ms": 600 },
  { "type": "eval", "expr": "(()=>{const g=window.__game;g.combat.toggleLock(g.tpCamera);return g.combat.lockTarget? 'locked '+ (g.combat.lockTarget.type||'boss') : 'nolock'})()" },
  { "type": "eval", "expr": "(()=>{const g=window.__game;const e=g.combat.enemies.find(x=>x.alive);const hp0=e.hp;g.player.startAttack(0,g.tpCamera);return 'hp0='+hp0})()" },
  { "type": "wait", "ms": 1800 },
  { "type": "eval", "expr": "(()=>{const g=window.__game;const e=g.combat.enemies[0];return JSON.stringify({enemyHp:e.hp,enemyState:e.state,focus:Math.round(g.player.focus*100)/100,playerState:g.player.state})})()" },
  { "type": "shot", "out": "downloads/fight1.png" },
  { "type": "eval", "expr": "(()=>{const g=window.__game;g.player.castStun(g.combat.enemies.filter(e=>e.alive));return 'cast'})()" },
  { "type": "wait", "ms": 1500 },
  { "type": "eval", "expr": "(()=>{const g=window.__game;const st=g.combat.enemies.filter(e=>e.state==='stunned').length;return JSON.stringify({stunned:st,stunCd:Math.round(g.player.stunCd)})})()" },
  { "type": "eval", "expr": "(()=>{const g=window.__game;g.player.hp=40;g.player.startDrink();return 'drink'})()" },
  { "type": "wait", "ms": 1600 },
  { "type": "eval", "expr": "JSON.stringify({hp:window.__game.player.hp,gourds:window.__game.player.gourds})" },
  { "type": "shot", "out": "downloads/fight2.png" }
]

[
  { "type": "eval", "expr": "(()=>{const g=window.__game;const e=g.combat.enemies;for(let i=0;i<5;i++){const en=e[i];en.group.position.set(g.player.position.x+3+i*1.5,0,g.player.position.z-6);en.state='idle';en.snapToGround();}g.player.castQuake();return 'cast'})()" },
  { "type": "wait", "ms": 1200 },
  { "type": "eval", "expr": "(()=>{const eb=window.__game.combat.earthBurial;for(let i=0;i<6;i++)eb.update(0.35);return JSON.stringify({t:Math.round(eb.time*10)/10,phaseLifted:eb.victims.filter(v=>v.ent.lifted).length,y:Math.round(eb.victims[0].ent.position.y*10)/10})})()" },
  { "type": "eval", "expr": "(()=>{const eb=window.__game.combat.earthBurial;for(let i=0;i<6;i++)eb.update(0.35);return JSON.stringify({t:Math.round(eb.time*10)/10,exploded:eb.exploded,aliveEnemies:window.__game.combat.enemies.filter(e=>e.alive).length})})()" },
  { "type": "eval", "expr": "(()=>{const eb=window.__game.combat.earthBurial;for(let i=0;i<8;i++)eb.update(0.3);return JSON.stringify({t:eb.active?Math.round(eb.time*10)/10:'done',active:eb.active,anyLifted:window.__game.combat.enemies.some(e=>e.lifted),aliveEnemies:window.__game.combat.enemies.filter(e=>e.alive).length})})()" },
  { "type": "eval", "expr": "(()=>{const g=window.__game;g.player.quakeCd=0;g.player.group.position.set(0,g.world.getHeight(0,-62),-62);g.player.snapToGround();return 'tp arena'})()" },
  { "type": "wait", "ms": 2500 },
  { "type": "eval", "expr": "(()=>{const g=window.__game;g.boss.setState('idle');g.player.castQuake();return 'quake on boss, bossState='+g.boss.state})()" },
  { "type": "wait", "ms": 1200 },
  { "type": "eval", "expr": "(()=>{const eb=window.__game.combat.earthBurial;for(let i=0;i<12;i++)eb.update(0.35);return JSON.stringify({bossLifted:window.__game.boss.lifted||'was',bossHp:window.__game.boss.hp,exploded:eb.exploded})})()" },
  { "type": "eval", "expr": "(()=>{const eb=window.__game.combat.earthBurial;for(let i=0;i<8;i++)eb.update(0.3);const g=window.__game;return JSON.stringify({active:eb.active,bossLifted:g.boss.lifted,bossHp:g.boss.hp,bossState:g.boss.state,errs:window.__errors})})()" }
]

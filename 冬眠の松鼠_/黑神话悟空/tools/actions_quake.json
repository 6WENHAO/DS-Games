[
  { "type": "eval", "expr": "(()=>{const g=window.__game;const e=g.combat.enemies;for(let i=0;i<5;i++){const en=e[i];en.group.position.set(g.player.position.x+3+i*1.5,0,g.player.position.z-6);en.state='idle';en.snapToGround();}return 'moved 5 enemies ahead'})()" },
  { "type": "eval", "expr": "(()=>{const g=window.__game;g.player.castQuake();return 'quake cast cd='+g.player.quakeCd})()" },
  { "type": "wait", "ms": 1500 },
  { "type": "eval", "expr": "JSON.stringify({active:window.__game.combat.earthBurial.active,victims:window.__game.combat.earthBurial.victims.length,rocks:window.__game.combat.earthBurial.rocks.length})" },
  { "type": "wait", "ms": 3000 },
  { "type": "shot", "out": "downloads/quake_lift.png" },
  { "type": "eval", "expr": "(()=>{const g=window.__game;const v=g.combat.earthBurial.victims[0];return JSON.stringify({liftedY:v?Math.round(v.ent.position.y*10)/10:'none',groundY:Math.round(g.world.getHeight(v.ent.position.x,v.ent.position.z)*10)/10,lifted:v?v.ent.lifted:false,time:Math.round(g.combat.earthBurial.time*10)/10})})()" },
  { "type": "wait", "ms": 12000 },
  { "type": "shot", "out": "downloads/quake_boom.png" },
  { "type": "eval", "expr": "JSON.stringify({active:window.__game.combat.earthBurial.active,exploded:window.__game.combat.earthBurial.exploded,aliveEnemies:window.__game.combat.enemies.filter(e=>e.alive).length,anyLifted:window.__game.combat.enemies.some(e=>e.lifted)})" },
  { "type": "wait", "ms": 6000 },
  { "type": "eval", "expr": "JSON.stringify({activeAfter:window.__game.combat.earthBurial.active,playerState:window.__game.player.state,errs:window.__errors})" }
]

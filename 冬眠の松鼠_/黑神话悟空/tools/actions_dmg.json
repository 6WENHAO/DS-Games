[
  { "type": "eval", "expr": "(()=>{const g=window.__game;const e=g.combat.enemies.find(x=>x.alive);e.state='idle';g.player.group.position.set(e.position.x+1.2,0,e.position.z);g.player.snapToGround();const d=e.position.clone().sub(g.player.position);g.player.yaw=Math.atan2(d.x,d.z);const hp0=e.hp;const hits=g.combat.meleeSweep({source:g.player,origin:g.player.position,yaw:g.player.yaw,range:2.9,arc:1.7,dmg:15,heavy:false});return JSON.stringify({hits,hp0,hp1:e.hp,state:e.state})})()" },

[
  { "type": "eval", "expr": "window.__game.input.keys.add('KeyW')" },
  { "type": "wait", "ms": 4000 },
  { "type": "shot", "out": "downloads/walk1.png" },
  { "type": "eval", "expr": "JSON.stringify(window.__game.player.position.toArray().map(v=>Math.round(v*10)/10))" },
  { "type": "wait", "ms": 4000 },
  { "type": "eval", "expr": "window.__game.input.keys.delete('KeyW')" },
  { "type": "shot", "out": "downloads/walk2.png" },
  { "type": "eval", "expr": "JSON.stringify({pos:window.__game.player.position.toArray().map(v=>Math.round(v*10)/10),state:window.__game.player.state,aliveEnemies:window.__game.combat.enemies.filter(e=>e.alive).length,risen:window.__game.combat.enemies.filter(e=>e.state!=='buried').length})" }
]

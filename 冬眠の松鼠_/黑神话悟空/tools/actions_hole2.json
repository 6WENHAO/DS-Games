[
  { "type": "eval", "expr": "(()=>{const g=window.__game;const e=g.combat.enemies;for(let i=0;i<6;i++){const en=e[i];en.group.position.set(g.player.position.x+3+i*2.2,0,g.player.position.z-8);en.state='idle';en.snapToGround();}g.player.castHole();return 'cast'})()" },
  { "type": "wait", "ms": 1200 },
  { "type": "eval", "expr": "(()=>{const bh=window.__game.combat.blackHole;for(let i=0;i<5;i++)bh.update(0.3);return JSON.stringify({t:Math.round(bh.time*10)/10,victims:bh.victims.length,debris:bh.debris.length,opened:bh.opened===true})})()" },
  { "type": "shot", "out": "downloads/hole_big.png" },
  { "type": "eval", "expr": "(()=>{const bh=window.__game.combat.blackHole;for(let i=0;i<10;i++)bh.update(0.3);const g=window.__game;return JSON.stringify({t:Math.round(bh.time*10)/10,swallowed:bh.victims.filter(v=>v.swallowed).length,debrisGone:bh.debris.filter(d=>d.gone).length,alive:g.combat.enemies.filter(e=>e.alive).length})})()" },
  { "type": "eval", "expr": "(()=>{const bh=window.__game.combat.blackHole;for(let i=0;i<10;i++)bh.update(0.3);const g=window.__game;return JSON.stringify({active:bh.active,alive:g.combat.enemies.filter(e=>e.alive).length,anyLifted:g.combat.enemies.some(e=>e.lifted),debrisLeft:bh.debris.length,flashCleared:document.getElementById('flash-layer').className===''})})()" },
  { "type": "eval", "expr": "JSON.stringify({errs:window.__errors})" }
]

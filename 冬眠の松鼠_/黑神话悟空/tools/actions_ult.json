[
  { "type": "eval", "expr": "(()=>{const g=window.__game;const e=g.combat.enemies;for(let i=0;i<4;i++){const en=e[i];en.group.position.set(g.player.position.x+2+i,0,g.player.position.z-2);en.state='idle';en.snapToGround();}return 'moved 4 enemies near player'})()" },
  { "type": "eval", "expr": "(()=>{const g=window.__game;g.player.castUlt();return 'ult cast, cd='+g.player.ultCd})()" },
  { "type": "wait", "ms": 2500 },
  { "type": "shot", "out": "downloads/ult1.png" },
  { "type": "eval", "expr": "JSON.stringify({aliveNear:window.__game.combat.enemies.filter(e=>e.alive&&e.position.distanceTo(window.__game.player.position)<18).length,totalAlive:window.__game.combat.enemies.filter(e=>e.alive).length})" },
  { "type": "eval", "expr": "(()=>{const g=window.__game;g.player.group.position.set(0,g.world.getHeight(0,-62),-62);g.player.snapToGround();return 'tp to arena'})()" },
  { "type": "wait", "ms": 2000 },
  { "type": "eval", "expr": "JSON.stringify({bossState:window.__game.boss.state,bossActive:window.__game.combat.bossActive})" },
  { "type": "wait", "ms": 5000 },
  { "type": "eval", "expr": "(()=>{const g=window.__game;g.player.ultCd=0;g.player.castUlt();return 'ult on boss'})()" },
  { "type": "wait", "ms": 3000 },
  { "type": "shot", "out": "downloads/ult2.png" },
  { "type": "eval", "expr": "JSON.stringify({bossState:window.__game.boss.state,bossHp:window.__game.boss.hp})" },
  { "type": "wait", "ms": 8000 },
  { "type": "eval", "expr": "JSON.stringify({gameState:window.__game.state,victoryShown:!document.getElementById('overlay-victory').classList.contains('hidden'),souls:window.__game.player.souls})" }
]
